  "main": "index.js",
  "scripts": {
    "serve": "http-server . -p 4173 -c-1",
    "validate:html": "vnu --errors-only index.html",
    "lint:html": "html-validate index.html",
    "lint:css": "stylelint css/styles.css",
    "test:links": "linkinator http://127.0.0.1:4173 --recurse",
    "test:browser": "playwright test",
    "test:visual": "playwright test tests/visual.spec.js",
    "test:visual:update": "playwright test tests/visual.spec.js --update-snapshots",
    "test:lighthouse": "lhci autorun",
    "test:static": "npm run validate:html && npm run lint:html && npm run lint:css",
    "test": "npm run test:static && npm run test:browser"
  },
